# Neon Postgres
DATABASE_URL=postgresql://user:pass@host/db?sslmode=require

# ManyChat
MANYCHAT_TOKEN=your_token_here
MANYCHAT_BASE=https://api.manychat.com/fb

# Dashboard auth — password for /login
ADMIN_PASSWORD=change_me

# Shared secret used by /api/bot/* routes (queue-analysis, claude-context,
# save-suggestion, new-lead). Set in Vercel env too.
BOT_SECRET=change_me

# Shared secret for ManyChat External Request → /api/bot/inbound-message
MANYCHAT_WEBHOOK_SECRET=change_me

# Base URL used by Server Actions to self-call API routes (local dev only).
# In Vercel, VERCEL_URL is auto-set and used instead.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# === WhatsApp bridge (replacing ManyChat — see CLAUDE.md "Bridge migration") ===
# Flip USE_BRIDGE=1 to route all tag/field/send calls through whatsapp-bridge-node
# and the DB-owned state instead of ManyChat. Leave USE_BRIDGE=0 to keep the
# legacy ManyChat HTTP path active.
USE_BRIDGE=0
BRIDGE_BASE=https://wa-bridge-yehuda.fly.dev
BRIDGE_TENANT_TOKEN=wat_your_tenant_token
# Set after registering a webhook subscription via the bridge admin API.
# Shown ONCE by POST /v1/subscriptions; store it here.
BRIDGE_WEBHOOK_SECRET=

# === Google Sheets — FB lead form gap visibility ===
# Sheet must be set to "Anyone with link can view" (no service account needed).
# Spreadsheet ID (the long token in the Sheet URL between /d/ and /edit).
GOOGLE_SHEETS_FB_LEADS_ID=
