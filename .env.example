# Neon Postgres
DATABASE_URL=postgresql://user:pass@host/db?sslmode=require

# ManyChat
MANYCHAT_TOKEN=your_token_here
MANYCHAT_BASE=https://api.manychat.com/fb

# Dashboard auth — password for /login
ADMIN_PASSWORD=change_me

# Shared secret used by /api/bot/* routes (queue-analysis, claude-context,
# save-suggestion, new-lead). Set in Vercel env too.
BOT_SECRET=change_me

# Shared secret for ManyChat External Request → /api/bot/inbound-message
MANYCHAT_WEBHOOK_SECRET=change_me

# Base URL used by Server Actions to self-call API routes (local dev only).
# In Vercel, VERCEL_URL is auto-set and used instead.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# === WhatsApp bridge (replacing ManyChat — see CLAUDE.md "Bridge migration") ===
# Flip USE_BRIDGE=1 to route all tag/field/send calls through whatsapp-bridge-node
# and the DB-owned state instead of ManyChat. Leave USE_BRIDGE=0 to keep the
# legacy ManyChat HTTP path active.
USE_BRIDGE=0
BRIDGE_BASE=https://wa-bridge-yehuda.fly.dev
BRIDGE_TENANT_TOKEN=wat_your_tenant_token
# Set after registering a webhook subscription via the bridge admin API.
# Shown ONCE by POST /v1/subscriptions; store it here.
BRIDGE_WEBHOOK_SECRET=

# === Google Sheets — FB lead form gap visibility ===
# Sheet must be set to "Anyone with link can view" (no service account needed).
# Spreadsheet ID (the long token in the Sheet URL between /d/ and /edit).
GOOGLE_SHEETS_FB_LEADS_ID=

# === GoHighLevel (GHL) CRM — API V2 ===
# Auth: either a Location Private Integration Token (preferred) OR an
# OAuth access token. Both work — set whichever you have.
GHL_API_KEY=
# Optional: pre-existing OAuth access token. GHL_API_KEY takes precedence.
GHL_ACCESS_TOKEN=
# Sub-account location id (the "sub-account" you're working in).
GHL_LOCATION_ID=
# Opportunity pipeline id. Populated after scripts/_ghl-bootstrap.ts run.
GHL_PIPELINE_ID=
# Toggle to mirror lead/message events from bridge → GHL.
ENABLE_GHL_SYNC=0
# Pipeline stage ids — one per local stage (8-stage journey model).
# Bootstrap script prints these after creating/matching stages in GHL.
GHL_STAGE_INITIAL_QUOTE_SENT=
GHL_STAGE_AWAITING_FIRST_RESPONSE=
GHL_STAGE_SHOWED_INTEREST=
GHL_STAGE_FACTORY_CHECK=
GHL_STAGE_FINAL_QUOTE_SENT=
GHL_STAGE_NEGOTIATING=
GHL_STAGE_WON=
GHL_STAGE_LOST=
# Virtual override stage used when leads.pipeline_flag = 'NEEDS_ELI'.
GHL_STAGE_NEEDS_ELI=
# GHL custom field id for loss reason (populated after bootstrap).
GHL_FIELD_LOSS_REASON=
# Shared secret used by GHL Custom Menu Links to authenticate iframe widgets.
# Generate: openssl rand -hex 32
# Used in URL: ?widget_token=<value>. Single value, single user — rotate by
# changing this var + redeploying. Calculator widget verifies on every request.
GHL_WIDGET_TOKEN=
# Subdomains allowed to embed widget iframes (X-Frame-Options + CSP). Comma-
# separated. Defaults to GHL + LeadConnector. Add custom domains if needed.
WIDGET_ALLOWED_FRAME_ANCESTORS=https://app.gohighlevel.com https://*.leadconnectorhq.com https://*.gohighlevel.com https://*.msgsndr.com

# Custom field ids (5 only — calculator embed reads the rest from Albadi DB).
# Bootstrap script (integrations/ghl/bootstrap.ts) creates fields + prints ids.
GHL_FIELD_MANYCHAT_SUB_ID=
GHL_FIELD_WA_JID=
GHL_FIELD_BOT_SUMMARY=
GHL_FIELD_QUOTE_TOTAL=
GHL_FIELD_PIPELINE_FLAG=
