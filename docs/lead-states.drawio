        <mxCell id="qtitle" value="Auto-responder questionnaire (leads.q_state, pipeline_stage IN (NULL, NEW))" style="text;html=1;align=left;verticalAlign=middle;fontSize=18;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="40" y="20" width="900" height="30" as="geometry" />
        </mxCell>
        <mxCell id="qstart" value="inbound, no q_state" style="ellipse;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1">
