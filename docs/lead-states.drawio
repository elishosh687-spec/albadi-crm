          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="eResume" edge="1" parent="1" source="botPaused" style="endArrow=classic;html=1;dashed=1;strokeColor=#82b366;" target="new" value="customer re-engages → auto-resume&#xa;(clear flags, reset follow_up_count)">
          <mxGeometry relative="1" as="geometry">
