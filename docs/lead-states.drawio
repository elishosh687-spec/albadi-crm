<mxfile host="app.diagrams.net" pages="3">
  <diagram name="Pipeline stages" id="pipeline">
    <mxGraphModel dx="1914" dy="642" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="900" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="title" parent="1" style="text;html=1;align=left;verticalAlign=middle;fontSize=18;fontStyle=1" value="Lead pipeline stages (leads.pipeline_stage) + orthogonal flags" vertex="1">
          <mxGeometry height="30" width="900" x="40" y="20" as="geometry" />
        </mxCell>
        <mxCell id="start" parent="1" style="ellipse;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" value="(inbound msg, no row)" vertex="1">
          <mxGeometry height="50" width="180" x="60" y="80" as="geometry" />
        </mxCell>
        <mxCell id="new" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontStyle=1" value="NEW&#xa;(autoresponder eligible — runs questionnaire while pipeline_stage stays NEW)" vertex="1">
          <mxGeometry height="80" width="200" x="60" y="180" as="geometry" />
        </mxCell>
        <mxCell id="N9cSt3JBm1Zua05FMt8O-1" edge="1" parent="1" source="qst" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;exitX=1;exitY=0.5;exitDx=0;exitDy=0;">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="490" y="160.0000000000001" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="qst" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;dashed=1;" value="QUESTIONNAIRE&#xa;(legacy stage — code never sets it;&#xa;real state lives in leads.q_state while pipeline_stage = NEW)" vertex="1">
          <mxGeometry height="80" width="240" x="290" y="180" as="geometry" />
        </mxCell>
        <mxCell id="wfact" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" value="WAITING_FACTORY&#xa;(Eli asked factory for price)" vertex="1">
          <mxGeometry height="80" width="200" x="560" y="180" as="geometry" />
        </mxCell>
        <mxCell id="quoted" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" value="QUOTED&#xa;(price sent to lead)" vertex="1">
          <mxGeometry height="80" width="200" x="790" y="180" as="geometry" />
        </mxCell>
        <mxCell id="neg" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" value="NEGOTIATING&#xa;(price too high / haggling)" vertex="1">
          <mxGeometry height="70" width="200" x="790" y="320" as="geometry" />
        </mxCell>
        <mxCell id="wcall" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" value="WAITING_CALL&#xa;(lead asked for call)" vertex="1">
          <mxGeometry height="70" width="200" x="560" y="320" as="geometry" />
        </mxCell>
        <mxCell id="prog" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" value="IN_PROGRESS&#xa;(Eli marked accepted — production / shipping)" vertex="1">
          <mxGeometry height="70" width="200" x="790" y="440" as="geometry" />
        </mxCell>
        <mxCell id="won" parent="1" style="ellipse;whiteSpace=wrap;html=1;fillColor=#b1ddf0;strokeColor=#10739e;fontStyle=1" value="WON&#xa;(deal closed)" vertex="1">
          <mxGeometry height="70" width="180" x="1020" y="440" as="geometry" />
        </mxCell>
        <mxCell id="dropped" parent="1" style="ellipse;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontStyle=1" value="DROPPED&#xa;(Eli-only after call —&#xa;NEVER set by bot)" vertex="1">
          <mxGeometry height="80" width="200" x="60" y="440" as="geometry" />
        </mxCell>
        <mxCell id="flagsheader" parent="1" style="text;html=1;align=left;verticalAlign=middle;fontSize=14;fontStyle=1" value="Orthogonal flags (set independent of pipeline_stage)" vertex="1">
          <mxGeometry height="24" width="500" x="60" y="600" as="geometry" />
        </mxCell>
        <mxCell id="needsEli" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontStyle=1;shape=mxgraph.flowchart.annotation_2;" value="pipeline_flag = NEEDS_ELI&#xa;(set by: 3 unanswered follow-ups, stop-word,&#xa;questionnaire bail, calc fail)&#xa;→ dashboard inbox flag + WA DM to Eli" vertex="1">
          <mxGeometry height="100" width="340" x="60" y="640" as="geometry" />
        </mxCell>
        <mxCell id="botPaused" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontStyle=1;shape=mxgraph.flowchart.annotation_2;" value="bot_paused = true&#xa;(set by: NEEDS_ELI escalation, stop-word, Eli dashboard toggle)&#xa;cleared by: customer inbound (auto-resume) OR Eli toggle&#xa;→ follow-up cron skips this lead" vertex="1">
          <mxGeometry height="100" width="340" x="420" y="640" as="geometry" />
        </mxCell>
        <mxCell id="followupNote" parent="1" style="text;html=1;align=left;verticalAlign=top;fontSize=11;whiteSpace=wrap;" value="Follow-up cron (every 15min, see page 3) drives ALL stages with cadence:&#xa;• NEW (mid-Q abandoned) → 1h, max 3&#xa;• QUOTED → 2h, max 3&#xa;• NEGOTIATING / WAITING_CALL → 2h, max 3&#xa;• WAITING_FACTORY → daily Eli DM only (no customer-side msg)&#xa;Quiet 21:00–09:00 Asia/Jerusalem. Skip Fri/Sat/holiday-eve/holiday." vertex="1">
          <mxGeometry height="140" width="500" x="780" y="640" as="geometry" />
        </mxCell>
        <mxCell id="e1" edge="1" parent="1" source="start" style="endArrow=classic;html=1;" target="new">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e2" edge="1" parent="1" source="new" style="endArrow=classic;html=1;dashed=1;" target="qst" value="opening + Q1 sent&#xa;(stage stays NEW)">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e3" edge="1" parent="1" source="qst" style="endArrow=classic;html=1;" target="wfact" value="Eli marks (custom quote needed)">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e3b" edge="1" parent="1" source="qst" style="endArrow=classic;html=1;" target="quoted" value="calc ok (auto)">
