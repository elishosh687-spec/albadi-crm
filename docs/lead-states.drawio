        <mxCell id="legend" parent="1" style="text;html=1;align=left;verticalAlign=top;fontSize=11;whiteSpace=wrap;" value="Legend:&#xa;blue = entry / autoresponder zone (NEW)&#xa;dashed blue = legacy stage placeholder (state actually lives in q_state)&#xa;yellow = waiting on Eli / factory / customer reply&#xa;green = quoted / progressing&#xa;cyan = won (terminal)&#xa;red pill = NEEDS_ELI flag (orthogonal)&#xa;purple pill = bot_paused flag (orthogonal)&#xa;red ellipse = DROPPED (terminal, Eli-only)" vertex="1">
          <mxGeometry height="180" width="340" x="1010" y="60" as="geometry" />
        </mxCell>
      </root>
