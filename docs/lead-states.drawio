          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e5" edge="1" parent="1" source="quoted" style="endArrow=classic;html=1;" target="neg" value="lead haggles">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e6" edge="1" parent="1" source="neg" style="endArrow=classic;html=1;" target="quoted" value="re-quote">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="1010" y="350" />
              <mxPoint x="1010" y="210" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="e7" edge="1" parent="1" source="quoted" style="endArrow=classic;html=1;" target="wcall" value="asks for call">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e8" edge="1" parent="1" source="wcall" style="endArrow=classic;html=1;" target="neg" value="call done">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e9" edge="1" parent="1" source="quoted" style="endArrow=classic;html=1;" target="prog" value="Eli marks accepted">
