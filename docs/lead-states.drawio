        </mxCell>
        <mxCell id="s6" value="step 6&#xa;asked handles" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="660" y="180" width="160" height="60" as="geometry" />
        </mxCell>
        <mxCell id="s7" value="step 7&#xa;asked colors" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="860" y="180" width="160" height="60" as="geometry" />
        </mxCell>
        <mxCell id="s8" value="step 8&#xa;calling calc API" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="860" y="300" width="160" height="60" as="geometry" />
        </mxCell>
        <mxCell id="s9" value="step 9 / doneAt&#xa;quote sent&#xa;→ pipeline_stage=QUOTED" style="ellipse;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="860" y="420" width="180" height="70" as="geometry" />
        </mxCell>
        <mxCell id="reask" value="re-ask&#xa;(unmatchedAt=1)" style="rhombus;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;" vertex="1" parent="1">
          <mxGeometry x="380" y="400" width="160" height="80" as="geometry" />
        </mxCell>
        <mxCell id="bailed" value="bailed=true&#xa;handoff to Eli" style="ellipse;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="60" y="420" width="180" height="70" as="geometry" />
        </mxCell>
        <mxCell id="q1" value="send OPENING + Q1" style="endArrow=classic;html=1;" edge="1" parent="1" source="qstart" target="s3">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="q2" value="match" style="endArrow=classic;html=1;" edge="1" parent="1" source="s3" target="s4">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="q3" value="match" style="endArrow=classic;html=1;" edge="1" parent="1" source="s4" target="s5">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="q4" value="match" style="endArrow=classic;html=1;" edge="1" parent="1" source="s5" target="s6">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="q5" value="match" style="endArrow=classic;html=1;" edge="1" parent="1" source="s6" target="s7">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="q6" value="match" style="endArrow=classic;html=1;" edge="1" parent="1" source="s7" target="s8">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="q7" value="calc ok" style="endArrow=classic;html=1;" edge="1" parent="1" source="s8" target="s9">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="qr1" value="unmatched #1" style="endArrow=classic;html=1;strokeColor=#d79b00;dashed=1;" edge="1" parent="1" source="s3" target="reask">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="qr2" style="endArrow=classic;html=1;strokeColor=#d79b00;dashed=1;" edge="1" parent="1" source="s4" target="reask">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="qr3" style="endArrow=classic;html=1;strokeColor=#d79b00;dashed=1;" edge="1" parent="1" source="s5" target="reask">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="qr4" style="endArrow=classic;html=1;strokeColor=#d79b00;dashed=1;" edge="1" parent="1" source="s6" target="reask">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="qr5" style="endArrow=classic;html=1;strokeColor=#d79b00;dashed=1;" edge="1" parent="1" source="s7" target="reask">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="qrback" value="match next inbound (stays on same step)" style="endArrow=classic;html=1;strokeColor=#d79b00;" edge="1" parent="1" source="reask" target="s5">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="qbail1" value="unmatched #2" style="endArrow=classic;html=1;strokeColor=#b85450;" edge="1" parent="1" source="reask" target="bailed">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="qbail2" value="calc fail" style="endArrow=classic;html=1;strokeColor=#b85450;" edge="1" parent="1" source="s8" target="bailed">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="600" y="330" />
              <mxPoint x="600" y="455" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="qlegend" value="Notes:&#xa;• state lives in leads.q_state JSONB&#xa;• runs ONLY when pipeline_stage IN (NULL, NEW) — Eli&#39;s in-flight conversations are NOT hijacked&#xa;• bailed=true OR doneAt set → autoresponder is no_op forever after&#xa;• re-ask box is logical, not a separate step — q_state.step stays put, only unmatchedAt increments" style="text;html=1;align=left;verticalAlign=top;fontSize=11;whiteSpace=wrap;" vertex="1" parent="1">
          <mxGeometry x="60" y="540" width="900" height="120" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram name="Follow-up engine" id="followup">
    <mxGraphModel dx="1422" dy="757" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="900" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="ftitle" value="Follow-up engine — /api/bot/followups (every 15 min)" style="text;html=1;align=left;verticalAlign=middle;fontSize=18;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="40" y="20" width="900" height="30" as="geometry" />
        </mxCell>
        <mxCell id="cron" value="cron tick (15 min)" style="ellipse;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="60" y="80" width="160" height="50" as="geometry" />
        </mxCell>
        <mxCell id="gate1" value="quiet hours?&#xa;21:00 → 09:00 Asia/Jerusalem" style="rhombus;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;" vertex="1" parent="1">
          <mxGeometry x="280" y="70" width="220" height="80" as="geometry" />
        </mxCell>
        <mxCell id="gate2" value="no-send day?&#xa;Fri / Sat / holiday eve / holiday&#xa;(Hebcal)" style="rhombus;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;" vertex="1" parent="1">
          <mxGeometry x="560" y="70" width="240" height="100" as="geometry" />
        </mxCell>
        <mxCell id="skip" value="skip tick&#xa;(do nothing)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#999999;" vertex="1" parent="1">
          <mxGeometry x="430" y="220" width="160" height="50" as="geometry" />
        </mxCell>
        <mxCell id="select" value="SELECT leads&#xa;WHERE NOT bot_paused&#xa;  AND pipeline_stage IN (NEW, QUESTIONNAIRE, QUOTED, NEGOTIATING, WAITING_CALL)&#xa;  AND last_follow_up_at + cadence(stage) &lt; now()&#xa;  AND follow_up_count &lt; 3" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="860" y="60" width="480" height="100" as="geometry" />
        </mxCell>
        <mxCell id="loop" value="for each lead →" style="text;html=1;align=center;fontStyle=2" vertex="1" parent="1">
          <mxGeometry x="900" y="180" width="400" height="20" as="geometry" />
        </mxCell>
        <mxCell id="stopcheck" value="(handled in webhook, not cron)&#xa;inbound stop-word → bot_paused=true,&#xa;NEEDS_ELI flag, DM Eli" style="text;html=1;align=left;fontSize=10;fontStyle=2;fillColor=#fff2cc;strokeColor=#d6b656" vertex="1" parent="1">
          <mxGeometry x="40" y="500" width="300" height="60" as="geometry" />
        </mxCell>
        <mxCell id="stage" value="branch on lead.pipeline_stage" style="rhombus;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;" vertex="1" parent="1">
          <mxGeometry x="1000" y="220" width="200" height="60" as="geometry" />
        </mxCell>
        <mxCell id="midq" value="QUESTIONNAIRE&#xa;cadence: every 1h&#xa;template: &#39;ראיתי שהתחלנו...&#39;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="60" y="320" width="220" height="80" as="geometry" />
        </mxCell>
        <mxCell id="quoted" value="QUOTED&#xa;cadence: every 2h&#xa;template: &#39;מה דעתך על ההצעה?&#39;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="320" y="320" width="220" height="80" as="geometry" />
        </mxCell>
        <mxCell id="negot" value="NEGOTIATING / WAITING_CALL&#xa;cadence: every 2h&#xa;template: &#39;רוצה לסגור פרטים?&#39;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="580" y="320" width="240" height="80" as="geometry" />
        </mxCell>
        <mxCell id="factwait" value="WAITING_FACTORY&#xa;cadence: daily&#xa;ELI-ONLY DM&#xa;&#39;ליד X מחכה Y ימים לציטוט&#39;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;" vertex="1" parent="1">
          <mxGeometry x="860" y="320" width="240" height="80" as="geometry" />
        </mxCell>
        <mxCell id="send" value="sendBridgeMessage(jid, template)&#xa;UPDATE leads SET&#xa;  follow_up_count += 1,&#xa;  last_follow_up_at = now()" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="320" y="460" width="320" height="80" as="geometry" />
        </mxCell>
